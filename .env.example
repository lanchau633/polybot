# ============================================================
# PolyBot — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Mode ---
DRY_RUN=true                          # true = paper trading, false = REAL MONEY

# --- Polymarket CLOB API ---
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# --- API-Sports (sportsbook odds) ---
# Sign up: https://dashboard.api-football.com/
APISPORTS_KEY=

# --- Discord Notifications ---
# Server Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=

# --- Anthropic Claude (base repo — news classification) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Twitter API v2 (optional — for news stream) ---
TWITTER_BEARER_TOKEN=

# --- Telegram (optional — for news stream) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# --- NewsAPI (optional) ---
NEWSAPI_KEY=

# --- Risk Limits (defaults are fine for paper trading) ---
MAX_DAILY_TRADES=50
MAX_OPEN_POSITIONS=10
MIN_BANKROLL_RESERVE=0.10
CONSECUTIVE_LOSS_LIMIT=5
EDGE_THRESHOLD=0.08
STOP_LOSS_THRESHOLD=0.15
KELLY_FRACTION=0.25
MIN_MARKET_VOLUME=10000
SPORTS_SCAN_INTERVAL=60

# --- Trading Limits ---
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100

# --- Volume Filter ---
MIN_VOLUME_USD=1000
MAX_VOLUME_USD=500000
MATERIALITY_THRESHOLD=0.6
SPEED_TARGET_SECONDS=5
